PORT=3000
NODE_ENV=development

# Google Gemini (chatbots, resume analysis)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# Comma-separated browser origins allowed by CORS
# Local dev:
FRONTEND_URL=http://localhost:5173
# Production example (set in Render dashboard):
# FRONTEND_URL=https://your-app.vercel.app,http://localhost:5173

# Public URL of this server (OAuth callbacks, upload URLs)
# Local dev:
BACKEND_URL=http://localhost:3000
# Production example:
# BACKEND_URL=https://joblet-server.onrender.com

# Firebase Admin SDK (Firebase Console → Settings → Service accounts)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_Key_Here\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Optional
SENTRY_DSN=
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET_KEY=

# Supabase (job scraper + interview sync)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Retell AI (voice mock interviews)
RETELL_API_KEY=
RETELL_AGENT_HR=
RETELL_AGENT_TECH=

# Google Calendar OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional chat web search
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
